{
  "name": "shiza-launcher",
  "version": "1.0.3",
  "description": "for dashulka and my discord friends",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "dev": "electron . --dev"
  },
  "build": {
    "appId": "com.shiza.launcher",
    "productName": "Shiza-mc",
    "forceCodeSigning": false,
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "sign": null,
      "signingHashAlgorithms": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "exxpion",
      "repo": "shiza-launcher"
    }
  },
  "dependencies": {
    "electron-log": "^5.4.4",
    "electron-updater": "^6.1.7",
    "extract-zip": "^2.0.1",
    "minecraft-launcher-core": "^3.18.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^23.6.0"
  }
}
